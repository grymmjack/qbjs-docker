{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "{{APP_NAME}}",
  "version": "{{APP_VERSION}}",
  "identifier": "{{APP_ID}}",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "{{APP_NAME}}",
        "width": 800,
        "height": 600,
        "minWidth": 320,
        "minHeight": 240,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
